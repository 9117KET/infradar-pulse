# === Vite (browser) — copy to `.env` ===
# Vercel: Project → Settings → Environment Variables → add for Production, Preview, Development.
# Redeploy after changing. Names must start with VITE_ to be embedded in the client bundle.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# === Supabase Edge Functions (hosted: Dashboard → Edge Functions → Secrets) ===
# CLI: supabase secrets set --project-ref <ref> PERPLEXITY_API_KEY=...
# Local serve: supabase functions serve --env-file .env  (from repo root; keep secrets out of git)
#
# Perplexity — search/research (contact-finder, data-enrichment, user-research, several agents)
PERPLEXITY_API_KEY=
#
# OpenAI-compatible LLM (edge functions: chat completions / tool calls). Use OpenAI, Azure OpenAI, or a local gateway (LiteLLM, vLLM, etc.).
OPENAI_API_KEY=
# Optional alias if you prefer not to use the name OPENAI_API_KEY:
# LLM_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
#
# Firecrawl — optional; scraping/search in user-research, contact-finder, market-intel, etc.
FIRECRAWL_API_KEY=
#
# Stripe (Edge Functions: stripe-webhook, create-checkout-session, create-portal-session)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Dashboard → Products (recurring monthly prices)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
# Supabase Edge: same as Dashboard → Settings → API (anon key for JWT validation in checkout/portal)
SUPABASE_ANON_KEY=
#
# Optional: npm run test:edge-security — point at local stack while VITE_* stays on hosted
# EDGE_SECURITY_BASE_URL=http://127.0.0.1:54321
# EDGE_SECURITY_ANON_KEY=<Publishable key from: npm run supabase -- status>
#
# JWT gate tests: use raw tokens OR password sign-in (staff user needs user_roles.role = admin|researcher)
# Or run: npm run sb:seed-security-test-users  (local Docker + supabase start) — prints / uses default emails + passwords
# SECURITY_TEST_ACCESS_TOKEN=
# SECURITY_TEST_ACCESS_TOKEN_STAFF=
# SECURITY_TEST_USER_EMAIL=
# SECURITY_TEST_USER_PASSWORD=
# SECURITY_TEST_STAFF_EMAIL=
# SECURITY_TEST_STAFF_PASSWORD=
#
# Hosted deploy (CLI logged in: supabase login): npm run sb:link → sb:db:push → sb:functions:deploy
# Mirror Edge secrets: Dashboard → Edge Functions → Secrets, or supabase secrets set --project-ref <ref>
# Optional: default site URL for redirects if Origin header missing
SITE_URL=http://localhost:5173
#
# Vite — publishable Stripe price IDs for Pricing page “Start trial” (optional; server falls back to STRIPE_PRICE_STARTER)
VITE_STRIPE_PRICE_STARTER=
