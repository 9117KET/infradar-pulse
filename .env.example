# === Vite (browser) — copy to `.env` ===
# Lovable Cloud autopopulates these; only edit when deploying outside Lovable.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Paddle client token (publishable). Lovable injects this automatically:
#   .env.development → test_... (sandbox)
#   .env.production  → live_... (live, after go-live verification)
# Override only if you self-host outside Lovable's deploy pipeline.
VITE_PAYMENTS_CLIENT_TOKEN=

# === Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets) ===
# These are set automatically by Lovable Cloud + the Paddle integration. Listed
# here so contributors know what the runtime expects.
#
# Paddle (set by enable_paddle_payments)
PADDLE_SANDBOX_API_KEY=
PADDLE_LIVE_API_KEY=
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=
LOVABLE_API_KEY=
#
# AI / research (managed by connectors where possible)
PERPLEXITY_API_KEY=
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
FIRECRAWL_API_KEY=
#
# Default Supabase secrets (set by platform)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_PUBLISHABLE_KEY=
#
# Optional fallback for redirect URLs when Origin header missing
SITE_URL=http://localhost:5173
#
# === Tests ===
# JWT gate tests: use raw tokens OR password sign-in (staff user needs user_roles.role = admin|researcher).
# Run: npm run sb:seed-security-test-users — prints / uses default emails + passwords.
# SECURITY_TEST_ACCESS_TOKEN=
# SECURITY_TEST_ACCESS_TOKEN_STAFF=
# SECURITY_TEST_USER_EMAIL=
# SECURITY_TEST_USER_PASSWORD=
# SECURITY_TEST_STAFF_EMAIL=
# SECURITY_TEST_STAFF_PASSWORD=
